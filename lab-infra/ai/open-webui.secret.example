# Copy this file to  open-webui.secret  (gitignored). up.sh loads it as a Secret.
# WEBUI_SECRET_KEY signs Open WebUI sessions — generate a random value:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
# Initial admin account for Open WebUI (ai-access: no open sign-up).
ADMIN_EMAIL=admin@oss500.local
ADMIN_PASSWORD=ChangeMe-Str0ng-Passw0rd!
# Bearer token Open WebUI presents to the AI gateway (the gateway treats the
# token value as the identity; "ml-" prefix grants the ml group). Any non-empty
# value works for the lab; the gateway rejects an empty/missing token with 401.
GATEWAY_TOKEN=ml-open-webui
