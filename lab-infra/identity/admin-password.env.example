# OSS-500 identity component — Keycloak admin bootstrap password.
#
# Copy this file to  admin-password.env  and set a real value. The real .env is
# gitignored and never committed (see lab-infra/README.md → Secrets hygiene).
# up.sh reads KEYCLOAK_ADMIN_PASSWORD from admin-password.env and creates the
# Kubernetes Secret `keycloak-admin` (key: admin-password) that values.yaml
# references via auth.existingSecret — so the password never lands in a manifest.
KEYCLOAK_ADMIN_PASSWORD=change-me-in-real-file
