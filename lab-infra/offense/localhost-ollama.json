{
  "rest": {
    "RestGenerator": {
      "name": "localhost-ollama",
      "uri": "http://localhost:11434/v1/chat/completions",
      "method": "post",
      "headers": {
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "model": "llama3.2:1b",
        "messages": [
          { "role": "user", "content": "$INPUT" }
        ]
      },
      "response_json": true,
      "response_json_field": "$.choices[0].message.content",
      "request_timeout": 30
    }
  }
}
