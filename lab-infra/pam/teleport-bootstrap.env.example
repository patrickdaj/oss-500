# teleport-bootstrap.env.example — copy to teleport-bootstrap.env (gitignored) and fill in.
# The real teleport-bootstrap.env holds local bootstrap values and MUST NOT be committed.

# First admin user created via `tctl users add` (the signup URL it prints is one-time).
TELEPORT_ADMIN_USER=alice

# Optional static join token for enrolling extra lab agents (kube/db/node).
# Generate a real, short-lived one instead of a static string:
#   kubectl -n oss500-identity exec deploy/teleport -- tctl tokens add --type=node,kube --ttl=1h
TELEPORT_JOIN_TOKEN=replace-me-with-a-real-short-lived-token

# Proxy address your tsh client connects to (port-forwarded in up.sh).
TELEPORT_PROXY=localhost:3080
